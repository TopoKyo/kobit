rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Admin lookup helper
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "chinchuarchibo@gmail.com" // Bootstrapped admin
      );
    }

    // --- Entity Validation ---

    function isValidContactRequest(data) {
      return data.keys().hasAll(['name', 'email', 'company', 'area', 'message', 'createdAt']) &&
             data.keys().size() >= 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.company is string && data.company.size() > 0 && data.company.size() <= 200 &&
             data.area is string && data.area.size() > 0 && data.area.size() <= 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isValidPortfolioCase(data) {
      return data.keys().hasAll(['title', 'challenge', 'solution', 'impact', 'createdAt', 'updatedAt']) &&
             // Optional fields: videoUrl, photos, testimonial, testimonialAuthor
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.challenge is string && data.challenge.size() > 0 && data.challenge.size() <= 5000 &&
             data.solution is string && data.solution.size() > 0 && data.solution.size() <= 5000 &&
             data.impact is string && data.impact.size() > 0 && data.impact.size() <= 5000 &&
             data.createdAt is timestamp &&
             data.updatedAt == request.time &&
             (!('videoUrl' in data) || data.videoUrl == null || (data.videoUrl is string && data.videoUrl.size() <= 1000)) &&
             (!('photos' in data) || data.photos == null || (data.photos is list && data.photos.size() <= 10)) &&
             (!('testimonial' in data) || data.testimonial == null || (data.testimonial is string && data.testimonial.size() <= 2000)) &&
             (!('testimonialAuthor' in data) || data.testimonialAuthor == null || (data.testimonialAuthor is string && data.testimonialAuthor.size() <= 200));
    }

    // --- Match Blocks ---

    match /portfolio/{caseId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidId(caseId) && isValidPortfolioCase(incoming());
      allow update: if isAdmin() && isValidPortfolioCase(incoming());
      allow delete: if isAdmin();
    }

    match /contactRequests/{requestId} {
      allow create: if isValidId(requestId) && isValidContactRequest(incoming());
      allow get, list, delete: if isAdmin();
      allow update: if isAdmin() && isValidContactRequest(incoming());
    }
    match /admins/{adminUid} {
      // Only admins can see other admins
      allow read: if isAdmin();
      
      // For bootstrapping, we allow the initial admin to register themselves if they match the email
      allow create: if isSignedIn() && (
        isAdmin() || 
        (adminUid == request.auth.uid && request.auth.token.email == "chinchuarchibo@gmail.com")
      );
      
      allow update, delete: if isAdmin();
    }
  }
}
