{
  "entities": {
    "ContactRequest": {
      "title": "Contact Request",
      "description": "Information submitted via the contact form by potential clients.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the contact person."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Contact email address."
        },
        "company": {
          "type": "string",
          "description": "Name of the company."
        },
        "area": {
          "type": "string",
          "description": "Area of interest for optimization."
        },
        "message": {
          "type": "string",
          "description": "Brief description of the problem or interest."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the request was created."
        }
      },
      "required": ["name", "email", "company", "area", "message", "createdAt"]
    },
    "Admin": {
      "title": "Administrator",
      "description": "Users with administrative access to view contact requests.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Admin email address."
        }
      },
      "required": ["email"]
    },
    "PortfolioCase": {
      "title": "Portfolio Case",
      "description": "A successful project showcase for the portfolio section.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "videoUrl": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "testimonial": { "type": "string" },
        "testimonialAuthor": { "type": "string" },
        "challenge": { "type": "string" },
        "solution": { "type": "string" },
        "impact": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "challenge", "solution", "impact", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/contactRequests/{requestId}": {
      "schema": "ContactRequest",
      "description": "Collection of contact requests from the landing page."
    },
    "/admins/{adminUid}": {
      "schema": "Admin",
      "description": "Collection of authorized administrators."
    },
    "/portfolio/{caseId}": {
      "schema": "PortfolioCase",
      "description": "Collection of portfolio showcases."
    }
  }
}
